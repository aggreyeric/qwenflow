{
  "name": "qwenflow",
  "version": "0.1.0",
  "description": "AI agent orchestration framework optimized for Qwen Cloud's multi-model strengths. Chain Qwen model calls (LLM → Tool → LLM → Output) with built-in retry, fallback, and observability.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "qwenflow": "dist/cli.js"
  },
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ci": "vitest run --reporter=verbose",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "qwen",
    "qwen-cloud",
    "ai",
    "agent",
    "orchestration",
    "workflow",
    "llm",
    "dashscope",
    "multi-modal"
  ],
  "author": "QwenFlow Contributors",
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@slack/bolt": "^4.0.0",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "zod": "^3.23.8",
    "@slack/bolt": "^3.22.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/supertest": "^6.0.0",
    "supertest": "^7.0.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
