# QwenFlow Environment Variables
# Copy to .env and fill in values

# Qwen Cloud (DashScope) API
QWEN_CLOUD_API_KEY=your_dashscope_api_key
DASHSCOPE_API_KEY=your_dashscope_api_key

# Gemini API (optional — for Gemini XPRIZE integration)
GEMINI_API_KEY=your_gemini_api_key

# Slack Integration (optional — for Slack Agent Builder hackathon)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your_signing_secret
SLACK_APP_TOKEN=xapp-your-app-token

# Server
PORT=3000
